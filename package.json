{
  "name": "gately",
  "private": true,
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=@gately/web",
    "dev:desktop": "turbo run dev --filter=@gately/desktop",
    "build:web": "turbo run build --filter=web",
    "build:landing": "turbo run build --filter=landing",
    "build:desktop": "turbo run build --filter=@gately/desktop",
    "build": "turbo run build",
    "deploy:web": "turbo run build --filter=web",
    "deploy:landing": "turbo run build --filter=landing",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^19.0.0-beta-0dec889-20250106",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
