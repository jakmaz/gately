# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies (all levels, not just root)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
dist/
build/
.next/
out/
.vercel/

# Turborepo cache
.turbo/

# Testing
coverage/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Environment files
.env*

# OS files
.DS_Store
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Misc
*.local
